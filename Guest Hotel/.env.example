# Copy to ".env" and adjust.

# Base URL of the Hotel-Manager API (used only when the booking flag below is ON).
VITE_API_URL=http://localhost:3000/api/v1

# Booking wiring is OFF by default. The public endpoints it calls
# (GET /rooms/categories, GET /rooms/availability, POST /bookings/public)
# and CORS for this origin do not exist on the API yet — see the plan's
# "Out of scope / future" section. Flip to "true" once they're added.
VITE_ENABLE_BOOKING_API=false

# Hotel-Manager web app (the guest portal / login lives here). The nav "Login"
# link points at ${VITE_PORTAL_URL}/guest-portal. Set to the deployed URL in prod.
VITE_PORTAL_URL=http://localhost:5173
