# ===================================================
# Hotel Management System — Backend Environment
# Copy this to .env and fill in your values
# ===================================================

# DATABASE (Supabase PostgreSQL)
# Get from: Supabase Dashboard > Project Settings > Database
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# SUPABASE
# Get from: Supabase Dashboard > Project Settings > API
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_ANON_KEY="eyJhbGci..."
SUPABASE_SERVICE_KEY="eyJhbGci..."
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# JWT
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-min-32-chars-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-different-min-32-chars-string"
JWT_REFRESH_EXPIRES_IN="7d"

# STRIPE
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# SENDGRID EMAIL
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY="SG...."
SENDGRID_FROM_EMAIL="noreply@yourhotel.com"
SENDGRID_FROM_NAME="Hotel Manager"

# SendGrid dynamic template IDs (create in SendGrid UI)
SENDGRID_TEMPLATE_BOOKING_CONFIRMATION=""
SENDGRID_TEMPLATE_CHECK_IN_REMINDER=""
SENDGRID_TEMPLATE_LOYALTY_DISCOUNT=""

# TWILIO SMS (Optional)
# Get from: https://console.twilio.com/
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER="+1234567890"

# APP SETTINGS
NODE_ENV="development"
PORT=3000
FRONTEND_URL="http://localhost:5173"

# TAX RATE (percentage, e.g. 10 = 10%)
TAX_RATE=10
